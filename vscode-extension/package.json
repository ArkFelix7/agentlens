{
  "name": "agentlens",
  "displayName": "AgentLens",
  "description": "Real-time AI agent observability in VS Code",
  "version": "0.2.0",
  "publisher": "agentlens",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Debuggers"],
  "keywords": ["ai", "agents", "observability", "llm", "tracing"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentlens.showLastTrace",
        "title": "AgentLens: Show Last Trace"
      },
      {
        "command": "agentlens.openDashboard",
        "title": "AgentLens: Open Dashboard"
      },
      {
        "command": "agentlens.toggleCostAnnotations",
        "title": "AgentLens: Toggle Cost Annotations"
      },
      {
        "command": "agentlens.connect",
        "title": "AgentLens: Connect to Server"
      }
    ],
    "configuration": {
      "title": "AgentLens",
      "properties": {
        "agentlens.serverUrl": {
          "type": "string",
          "default": "http://localhost:8766",
          "description": "AgentLens server URL"
        },
        "agentlens.showCostAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Show inline cost/latency annotations on @trace decorated functions"
        },
        "agentlens.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to server on startup"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentlens-sidebar",
          "title": "AgentLens",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "agentlens-sidebar": [
        {
          "type": "webview",
          "id": "agentlens.tracePanel",
          "name": "Traces"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
